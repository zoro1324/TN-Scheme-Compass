# Copy this file to .env and fill your keys.
GROQ_API_KEY=
TAVILY_API_KEY=

# Web app settings
APP_NAME=TN Scheme Compass API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173
# Option A: Provide full URL directly
MYSQL_URL=
# Option B: Provide parts below (used when MYSQL_URL is empty)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tn_scheme_compass
SCHEME_CSV_PATH=data_collection/outputs/welfare_schemes_tamil_nadu.csv
CHROMA_PATH=chroma_store
CHROMA_COLLECTION_NAME=tn_welfare_schemes
RETRIEVAL_TOP_K=5

# Optional tuning
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434
GROQ_MAX_RETRIES=4
GROQ_BACKOFF_SECONDS=1.5
REQUEST_TIMEOUT_SECONDS=30
MAX_RESULTS_PER_QUERY=20
MAX_PAGES=250
MIN_CONFIDENCE=0.55
